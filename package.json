{
  "name": "xstream",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
